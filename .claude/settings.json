{
  "extraKnownMarketplaces": {
    "justanotherspy": {
      "source": { "source": "github", "repo": "justanotherspy/claude-plugins" }
    }
  },
  "enabledPlugins": {
    "shuck@justanotherspy": true
  },
  "permissions": {
    "allow": [
      "Bash(go:*)",
      "Bash(make:*)",
      "Bash(golangci-lint:*)",
      "Bash(goreleaser:*)",
      "Bash(gopls:*)",
      "Bash(gofmt:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "mcp__shuck__check_compliance",
      "mcp__shuck__inspect_action",
      "mcp__shuck__inspect_images",
      "mcp__shuck__inspect_logs",
      "mcp__shuck__inspect_reviews",
      "mcp__shuck__inspect_security"
    ]
  },
  "env": {
    "GOTOOLCHAIN": "auto",
    "GOFLAGS": "-mod=mod"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v gopls >/dev/null 2>&1 || go install golang.org/x/tools/gopls@latest; go mod download >/dev/null 2>&1 || true"
          }
        ]
      }
    ]
  }
}
