{
  "go": {
    "command": "gopls",
    "args": ["serve"],
    "extensionToLanguage": {
      ".go": "go"
    },
    "settings": {
      "gopls": {
        "staticcheck": true,
        "analyses": {
          "nilness": true,
          "shadow": true,
          "unusedparams": true,
          "unusedwrite": true
        },
        "hints": {
          "assignVariableTypes": true,
          "compositeLiteralFields": true,
          "constantValues": true,
          "functionTypeParameters": true,
          "parameterNames": true,
          "rangeVariableTypes": true
        }
      }
    },
    "startupTimeout": 30000,
    "maxRestarts": 3
  }
}
