# --verbose turns on debug logging, which goes to stderr (stdout stays clean).
exec go-template --verbose version
stdout 'go-template e2e'
stderr 'level=DEBUG'
stderr 'configuration loaded'

# The same is configurable via the GO_TEMPLATE_ env prefix.
env GO_TEMPLATE_LOG_FORMAT=json
exec go-template --verbose version
stderr '"level":"DEBUG"'

# An unknown command fails with a non-zero exit and a helpful message.
! exec go-template definitely-not-a-command
stderr 'unknown command'
